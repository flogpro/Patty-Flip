{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "pattyflip",
  "post": {
    "dir": "webroot",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall",
        "inline": true
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "permissions": {
    "redis": true,
    "reddit": true
  },
  "menu": {
    "items": [
      {
        "label": "Create Patty Flipper post",
        "description": "Create a Patty Flipper game post",
        "endpoint": "/internal/menu/create-patty-flipper-post",
        "location": "subreddit"
      }
    ]
  },
  "scripts": {
    "dev": "npm run build:client -- --watch & npm run build:server -- --watch",
    "build": "npm run build:client && npm run build:server"
  },
  "dev": {
    "subreddit": "pattyflip_dev"
  }
}
