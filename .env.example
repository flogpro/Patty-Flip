# Skip the “source code zip” confirmation when running `npx devvit publish` (set to 1).
# Or pick “don’t ask again” in the CLI once; it writes this into .env for you.
# DEVVIT_ALLOW_SOURCE_UPLOAD=1

# Optional: default subreddit for Devvit playtest (see devvit.json `dev.subreddit`)
# DEVVIT_SUBREDDIT=my_test_sub

# Local API only (npm run dev:server / npm run dev)
# LOCAL_USERNAME=player1
# LOCAL_API_PORT=3001
